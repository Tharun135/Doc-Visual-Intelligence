!theme plain
' ────────────────────────────────────────────────────────────────
' Doc-Visual-Intelligence Corporate Theme for PlantUML
' ────────────────────────────────────────────────────────────────
' This theme centralizes all styling for workflow, sequence,
' component, and decision diagrams to ensure visual consistency
' across the entire documentation pipeline.
' ────────────────────────────────────────────────────────────────

' ─── Colors ───────────────────────────────────────────────────
' Siemens documentation-diagram palette.

!define COLOR_BG           #000028
!define COLOR_ACTIVITY     #009999
!define COLOR_ACTIVITY_DK  #00646E
!define COLOR_DECISION     #FFD732
!define COLOR_DECISION_DK  #F7C600
!define COLOR_START        #00FFB9
!define COLOR_END          #EF0137
!define COLOR_CONNECTOR    #00646E
!define COLOR_TEXT_DARK    #000028
!define COLOR_TEXT_LIGHT   #FFFFFF

' ─── Typography ───────────────────────────────────────────────
skinparam DefaultFontFamily "Segoe UI", "Roboto", sans-serif
skinparam DefaultFontSize 14
skinparam DefaultFontStyle normal
skinparam DefaultFontColor COLOR_TEXT_LIGHT
skinparam Shadowing false

' ─── Title Styling ────────────────────────────────────────────
skinparam TitleFontSize 18
skinparam TitleFontStyle bold
skinparam TitleFontColor COLOR_TEXT_LIGHT

' ─── Activity Diagram Styling ─────────────────────────────────
skinparam activity {
    BackgroundColor    COLOR_ACTIVITY
    BorderColor        COLOR_ACTIVITY_DK
    BorderThickness    3
    FontColor          COLOR_TEXT_LIGHT
    FontName           "Segoe UI", "Roboto", sans-serif
    FontSize           15
    FontStyle          normal
    Padding            20
    Margin             14
}

skinparam activityDiamond {
    BackgroundColor    COLOR_DECISION
    BorderColor        COLOR_DECISION_DK
    BorderThickness    3
    FontColor          COLOR_TEXT_DARK
    FontSize           15
}

skinparam activityBar {
    BackgroundColor    COLOR_ACTIVITY
    BorderColor        COLOR_ACTIVITY_DK
    BorderThickness    2
}

' ─── Arrow/Connector Styling ──────────────────────────────────
skinparam Arrow {
    Color              COLOR_CONNECTOR
    FontColor          COLOR_TEXT_LIGHT
    FontSize           13
    Thickness          4
    LineStyle          solid
}

skinparam Connector {
    LineStyle          solid
    LineThickness      4
}

' ─── Start/End Node Styling ───────────────────────────────────
skinparam Start {
    BackgroundColor    COLOR_START
    BorderColor        COLOR_ACTIVITY_DK
    BorderThickness    3
}

skinparam End {
    BackgroundColor    COLOR_END
    BorderColor        COLOR_END
    BorderThickness    3
}

skinparam activityStartColor COLOR_START
skinparam activityEndColor COLOR_END
skinparam activityArrowColor COLOR_CONNECTOR
skinparam ArrowThickness 4
skinparam nodesep 70
skinparam ranksep 90

' ─── Default Styling ──────────────────────────────────────────
skinparam Default {
    FontColor          COLOR_TEXT_LIGHT
    FontSize           14
}

' ─── Legend & Component Styling ───────────────────────────────
skinparam Component {
    BackgroundColor    COLOR_ACTIVITY
    BorderColor        COLOR_ACTIVITY_DK
    BorderThickness    2
    FontColor          COLOR_TEXT_LIGHT
}

skinparam Sequence {
    ActorBackgroundColor   COLOR_ACTIVITY
    ActorBorderColor       COLOR_ACTIVITY_DK
    ActorFontColor         COLOR_TEXT_LIGHT
    ParticipantBackgroundColor  COLOR_ACTIVITY
    ParticipantBorderColor      COLOR_ACTIVITY_DK
    ParticipantFontColor        COLOR_TEXT_LIGHT
}

' ─── Backgrounds & Padding ────────────────────────────────────
skinparam backgroundColor COLOR_BG
skinparam Padding 20
skinparam Margin 10

' ─── ClassDiagram Styling ─────────────────────────────────────
skinparam Class {
    BackgroundColor    COLOR_ACTIVITY
    BorderColor        COLOR_ACTIVITY_DK
    BorderThickness    2
    FontColor          COLOR_TEXT_LIGHT
}
